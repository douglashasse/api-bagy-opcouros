# Servidor
PORT=3099
HOST=0.0.0.0
NODE_ENV=development

# Chave interna usada pelo n8n para chamar esta API.
# Esta chave e admin e pode chamar rotas de escrita/manutencao.
OPCOUROS_API_KEY=troque-por-uma-chave-interna-forte

# Chave somente leitura para chatbot, landing pages e consultas seguras.
OPCOUROS_READ_API_KEY=troque-por-outra-chave-somente-leitura

# Bagy API atual, criada em Configuracoes > APIs e Webhooks.
BAGY_API_BASE=https://api.dooca.store
BAGY_API_MODE=dooca
BAGY_ACCESS_TOKEN=cole-o-token-da-bagy-aqui-localmente

# Opcional: se a Bagy tiver fornecido refresh token.
BAGY_REFRESH_TOKEN=

# Opcional: se usarmos fluxo OAuth de app no futuro.
BAGY_CONSUMER_KEY=
BAGY_CONSUMER_SECRET=

# Opcional: segredo para validar webhook recebido da Bagy.
BAGY_WEBHOOK_SECRET=

# Opcional: persistencia simples de tokens renovados.
BAGY_TOKEN_STORE_PATH=./data/bagy-token.json
